# ============================================================
# AI4ELLM MinerU Dockerfile — 独立 OCR 基础镜像
# ============================================================
# MinerU (magic-pdf) 有特定版本要求：
#   - transformers==4.49.0（公式识别 UnimerMBart 与新版不兼容）
#   - CUDA 11.8 PyTorch wheels
#   - Python 3.10
# 因此不复用 aigc-base:torch210（transformers 5.8.1），独立构建。
#
# Build:
#   docker build -f Dockerfile.mineru -t ai4ellm-mineru:latest .
#
# 此镜像可作为 corpus 容器的基础镜像。
# ============================================================

ARG CUDA_VERSION=12.8.0
ARG PYTHON_VERSION=3.10

# ── Base image: NVIDIA CUDA Ubuntu（使用本地已有镜像）──
FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu22.04

ARG PYTHON_VERSION
ARG DEBIAN_FRONTEND=noninteractive

# ── 系统依赖 ──
RUN apt-get update && apt-get install -y --no-install-recommends \
        python${PYTHON_VERSION} \
        python${PYTHON_VERSION}-venv \
        python${PYTHON_VERSION}-dev \
        python3-pip \
        git \
        curl \
        wget \
        ca-certificates \
        # OpenCV / OCR / MinerU 运行时
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxrender1 \
        libxext6 \
        libgomp1 \
        # PDF 工具
        poppler-utils \
        # LibreOffice: Office 文档 → PDF 转换
        libreoffice \
        libreoffice-writer \
        libreoffice-impress \
        # 中文字体
        fonts-noto-cjk \
        fonts-wqy-zenhei \
    && rm -rf /var/lib/apt/lists/*

# ── 设置 Python 别名 ──
RUN update-alternatives --install /usr/bin/python python /usr/bin/python${PYTHON_VERSION} 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python${PYTHON_VERSION} 1

# ── 工作目录 ──
WORKDIR /app

# ── Python 依赖 ──
# PyTorch CUDA 12.8 wheels（适配 RTX 5090 Blackwell sm_120）
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
        torch torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cu128

# MinerU (magic-pdf[full]) 1.3.12 + transformers 锁定版本
RUN pip install --no-cache-dir \
        "magic-pdf[full]==1.3.12" \
        "transformers==4.49.0" \
        PyMuPDF \
        PyPDF2 \
        python-docx \
        python-pptx \
        sentence-transformers \
        numpy \
        loguru \
        tqdm \
        chardet \
        PyYAML

# ── 创建必要目录 ──
RUN mkdir -p /app/models_cache /app/input_docs /app/output

# ── 环境变量 ──
ENV PYTHONUNBUFFERED=1 \
    HF_HOME=/app/models_cache/huggingface \
    TORCH_HOME=/app/models_cache/torch \
    MODELSCOPE_CACHE=/app/models_cache/modelscope

# 默认命令
CMD ["python", "-c", "import magic_pdf; print('MinerU ready')"]
